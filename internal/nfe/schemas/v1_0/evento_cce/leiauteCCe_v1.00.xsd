        </annotation>
      </element>
      <element xmlns="http://www.w3.org/2001/XMLSchema" name="retEvento" type="TretEvento" minOccurs="0" maxOccurs="20"></element>
    </sequence>
    <attribute xmlns="http://www.w3.org/2001/XMLSchema" name="versao" type="TVerEnvEvento" use="required"></attribute>
  </complexType>
  <complexType xmlns="http://www.w3.org/2001/XMLSchema" name="TProcEvento">
    <annotation xmlns="http://www.w3.org/2001/XMLSchema">
      <documentation xmlns="http://www.w3.org/2001/XMLSchema">Tipo procEvento</documentation>
