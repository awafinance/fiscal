  <simpleType xmlns="http://www.w3.org/2001/XMLSchema" name="TVerMDFeConsultaDFe">
    <annotation xmlns="http://www.w3.org/2001/XMLSchema">
      <documentation xmlns="http://www.w3.org/2001/XMLSchema"> Tipo Versão do Consulta DFe de MDF-e - 3.00</documentation>
