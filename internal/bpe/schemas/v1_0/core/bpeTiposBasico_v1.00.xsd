<?xml version="1.0" encoding="UTF-8"?>
<schema xmlns="http://www.w3.org/2001/XMLSchema" xmlns:ds="http://www.w3.org/2000/09/xmldsig#" xmlns:xs="http://www.w3.org/2001/XMLSchema" targetNamespace="http://www.portalfiscal.inf.br/bpe" elementFormDefault="qualified" attributeFormDefault="unqualified">
  <import namespace="http://www.w3.org/2000/09/xmldsig#" schemaLocation="xmldsig-core-schema_v1.01.xsd"></import>
  <include schemaLocation="tiposGeralBPe_v1.00.xsd"></include>
  <simpleType name="TTipoBPeTM">
    <annotation>
      <documentation>Tipo de BP-e Transporte Metropolitano</documentation>
    </annotation>
    <restriction base="xs:string">
      <whiteSpace value="preserve"></whiteSpace>
      <enumeration value="4"></enumeration>
    </restriction>
  </simpleType>
  <simpleType name="TAnon_serie_1">
    <restriction base="TSerie"></restriction>
  </simpleType>
  <simpleType name="TAnon_cBP_1">
    <restriction base="xs:string">
      <whiteSpace value="preserve"></whiteSpace>
      <pattern value="[0-9]{8}"></pattern>
    </restriction>
  </simpleType>
  <simpleType name="TAnon_cDV_1">
    <restriction base="xs:string">
      <whiteSpace value="preserve"></whiteSpace>
      <pattern value="[0-9]{1}"></pattern>
    </restriction>
  </simpleType>
  <simpleType name="TAnon_modal_1">
    <restriction base="TModal"></restriction>
  </simpleType>
  <simpleType name="TAnon_tpEmis_1">
    <restriction base="xs:string">
      <whiteSpace value="preserve"></whiteSpace>
      <enumeration value="1"></enumeration>
      <enumeration value="2"></enumeration>
    </restriction>
  </simpleType>
  <simpleType name="TAnon_verProc_1">
    <restriction base="TString">
      <minLength value="1"></minLength>
      <maxLength value="20"></maxLength>
    </restriction>
  </simpleType>
  <simpleType name="TAnon_xJust_1">
    <restriction base="TString">
      <minLength value="15"></minLength>
      <maxLength value="256"></maxLength>
    </restriction>
  </simpleType>
  <complexType name="TAnonComplex_ide_1">
    <sequence>
      <element name="cUF" type="TCodUfIBGE">
        <annotation>
          <documentation>Código da UF do emitente do BP-e</documentation>
          <documentation>Código da UF do emitente do Documento Fiscal. Utilizar a
Tabela do IBGE de código de unidades da federação.</documentation>
        </annotation>
      </element>
      <element name="tpAmb" type="TAmb">
        <annotation>
          <documentation>Tipo do Ambiente</documentation>
          <documentation>1 - Produção
2 - Homologação</documentation>
        </annotation>
      </element>
      <element name="mod" type="TModBPe">
        <annotation>
          <documentation>Modelo do Bilhete de Passagem</documentation>
          <documentation>Utilizar o código 63 para identificação do BP-e</documentation>
        </annotation>
      </element>
      <element name="serie" type="TAnon_serie_1">
        <annotation>
          <documentation>Série do documento fiscal</documentation>
          <documentation>Informar a série do documento fiscal (informar zero se inexistente).</documentation>
        </annotation>
      </element>
      <element name="nBP" type="TNF">
        <annotation>
          <documentation>Número do bilhete de passagem</documentation>
          <documentation>Número que identifica o bilhete 1 a 999999999.</documentation>
        </annotation>
      </element>
      <element name="cBP" type="TAnon_cBP_1">
        <annotation>
          <documentation>Código numérico que compõe a Chave de Acesso.</documentation>
          <documentation>Código aleatório gerado pelo emitente, com o objetivo de evitar acessos indevidos ao documento.</documentation>
        </annotation>
      </element>
      <element name="cDV" type="TAnon_cDV_1">
        <annotation>
          <documentation>Digito verificador da chave de acesso</documentation>
          <documentation>Informar o dígito  de controle da chave de acesso do BP-e, que deve ser calculado com a aplicação do algoritmo módulo 11 (base 2,9) da chave de acesso.</documentation>
        </annotation>
      </element>
      <element name="modal" type="TAnon_modal_1">
        <annotation>
          <documentation>Modalidade de transporte</documentation>
          <documentation>1 - Rodoviário; 3 - Aquaviário; 4 - Ferroviário.</documentation>
        </annotation>
      </element>
      <element name="dhEmi" type="TDateTimeUTC">
        <annotation>
          <documentation>Data e hora de emissão do Bilhete de Passagem</documentation>
          <documentation>Formato AAAA-MM-DDTHH:MM:DD TZD</documentation>
        </annotation>
      </element>
      <element name="dCompet" type="TData">
        <annotation>
          <documentation>Data da Competência a que se refere o Transporte Metropolitano</documentation>
          <documentation>Formato AAAA-MM-DDTHH:MM:DD TZD</documentation>
        </annotation>
      </element>
      <element name="tpEmis" type="TAnon_tpEmis_1">
        <annotation>
          <documentation>Forma de emissão do Bilhete (Normal ou Contingência Off-Line)</documentation>
          <documentation>1 - Normal
; 2 - Contingência Off-Line</documentation>
        </annotation>
      </element>
      <element name="verProc" type="TAnon_verProc_1">
        <annotation>
          <documentation>Versão do processo de emissão</documentation>
          <documentation>Informar a versão do aplicativo emissor de BP-e.</documentation>
        </annotation>
      </element>
      <element name="tpBPe" type="TTipoBPeTM">
        <annotation>
          <documentation>Tipo do BP-e</documentation>
          <documentation>4 - BP-e Transporte Metropolitano</documentation>
        </annotation>
      </element>
      <element name="CFOP" type="TCfop">
        <annotation>
          <documentation>Código Fiscal de Operações e Prestações</documentation>
        </annotation>
      </element>
      <sequence minOccurs="0">
        <annotation>
          <documentation>Informar apenas
para tpEmis diferente de 1</documentation>
        </annotation>
        <element name="dhCont" type="TDateTimeUTC">
          <annotation>
            <documentation>Data e Hora da entrada em contingência</documentation>
            <documentation>Informar a data e hora no formato AAAA-MM-DDTHH:MM:SS</documentation>
          </annotation>
        </element>
        <element name="xJust" type="TAnon_xJust_1">
          <annotation>
            <documentation>Justificativa da entrada em contingência</documentation>
          </annotation>
        </element>
      </sequence>
    </sequence>
  </complexType>
  <simpleType name="TAnon_IE_1">
    <restriction base="TIe"></restriction>
  </simpleType>
  <simpleType name="TAnon_IEST_1">
    <restriction base="TIe"></restriction>
  </simpleType>
  <simpleType name="TAnon_xNome_1">
    <restriction base="TString">
      <maxLength value="60"></maxLength>
      <minLength value="2"></minLength>
    </restriction>
  </simpleType>
  <simpleType name="TAnon_xFant_1">
    <restriction base="TString">
      <maxLength value="60"></maxLength>
      <minLength value="1"></minLength>
    </restriction>
  </simpleType>
  <simpleType name="TAnon_IM_1">
    <restriction base="TString">
      <minLength value="1"></minLength>
      <maxLength value="15"></maxLength>
    </restriction>
  </simpleType>
  <simpleType name="TAnon_CNAE_1">
    <restriction base="xs:string">
      <whiteSpace value="preserve"></whiteSpace>
      <pattern value="[0-9]{7}"></pattern>
    </restriction>
  </simpleType>
  <simpleType name="TAnon_CRT_1">
    <restriction base="xs:string">
      <whiteSpace value="preserve"></whiteSpace>
      <enumeration value="1"></enumeration>
      <enumeration value="2"></enumeration>
      <enumeration value="3"></enumeration>
    </restriction>
  </simpleType>
  <simpleType name="TAnon_TAR_1">
    <restriction base="xs:string">
      <whiteSpace value="preserve"></whiteSpace>
      <minLength value="1"></minLength>
      <maxLength value="20"></maxLength>
    </restriction>
  </simpleType>
  <complexType name="TAnonComplex_emit_1">
    <sequence>
      <element name="CNPJ" type="TCnpj">
        <annotation>
          <documentation>CNPJ do emitente</documentation>
          <documentation>Informar zeros não significativos</documentation>
        </annotation>
      </element>
      <element name="IE" type="TAnon_IE_1">
        <annotation>
          <documentation>Inscrição Estadual do emitente</documentation>
        </annotation>
      </element>
      <element name="IEST" minOccurs="0" type="TAnon_IEST_1">
        <annotation>
          <documentation>Inscrição Estadual do Substituto Tributário</documentation>
        </annotation>
      </element>
      <element name="xNome" type="TAnon_xNome_1">
        <annotation>
          <documentation>Razão social ou Nome do emitente</documentation>
        </annotation>
      </element>
      <element name="xFant" minOccurs="0" type="TAnon_xFant_1">
        <annotation>
          <documentation>Nome fantasia do emitente</documentation>
        </annotation>
      </element>
      <sequence minOccurs="0">
        <annotation>
          <documentation>Grupo de informações de interesse da Prefeitura</documentation>
          <documentation>Este campo deve ser informado, quando ocorrer a emissão de BP-e conjugado, com prestação de serviços sujeitos ao ISSQN.</documentation>
        </annotation>
        <element name="IM" type="TAnon_IM_1">
          <annotation>
            <documentation>Inscrição Municipal</documentation>
          </annotation>
        </element>
        <element name="CNAE" type="TAnon_CNAE_1">
          <annotation>
            <documentation>CNAE Fiscal</documentation>
          </annotation>
        </element>
      </sequence>
      <element name="CRT" type="TAnon_CRT_1">
        <annotation>
          <documentation>Código de Regime Tributário.</documentation>
          <documentation>Este campo será obrigatoriamente preenchido com:
1 – Simples Nacional;
2 – Simples Nacional – excesso de sublimite de receita bruta;
3 – Regime Normal.</documentation>
        </annotation>
      </element>
      <element name="enderEmit" type="TEndeEmi">
        <annotation>
          <documentation>Endereço do emitente</documentation>
        </annotation>
      </element>
      <element name="TAR" minOccurs="0" type="TAnon_TAR_1">
        <annotation>
          <documentation>Termo de Autorização de Serviço Regular</documentation>
          <documentation>Registro obrigatório do emitente do BP-e junto à ANTT para exercer a atividade</documentation>
        </annotation>
      </element>
    </sequence>
  </complexType>
  <simpleType name="TAnon_prefixo_1">
    <restriction base="xs:string">
      <whiteSpace value="preserve"></whiteSpace>
      <minLength value="1"></minLength>
      <maxLength value="20"></maxLength>
    </restriction>
  </simpleType>
  <simpleType name="TAnon_nContInicio_1">
    <restriction base="xs:string">
      <whiteSpace value="preserve"></whiteSpace>
      <minLength value="1"></minLength>
      <maxLength value="20"></maxLength>
    </restriction>
  </simpleType>
  <simpleType name="TAnon_nContFim_1">
    <restriction base="xs:string">
      <whiteSpace value="preserve"></whiteSpace>
      <minLength value="1"></minLength>
      <maxLength value="20"></maxLength>
    </restriction>
  </simpleType>
  <simpleType name="TAnon_qPass_1">
    <restriction base="xs:string">
      <whiteSpace value="preserve"></whiteSpace>
      <minLength value="1"></minLength>
      <maxLength value="20"></maxLength>
    </restriction>
  </simpleType>
  <simpleType name="TAnon_infAdFisco_1">
    <restriction base="TString">
      <maxLength value="2000"></maxLength>
      <minLength value="1"></minLength>
    </restriction>
  </simpleType>
  <complexType name="TAnonComplex_imp_1">
    <sequence>
      <element name="ICMS" type="TImp">
        <annotation>
          <documentation>Informações relativas ao ICMS</documentation>
          <documentation></documentation>
        </annotation>
      </element>
      <element name="infAdFisco" minOccurs="0" type="TAnon_infAdFisco_1">
        <annotation>
          <documentation>Informações adicionais de interesse do Fisco</documentation>
          <documentation>Norma referenciada, informações complementares, etc</documentation>
        </annotation>
      </element>
    </sequence>
  </complexType>
  <simpleType name="TAnon_xNome_2">
    <restriction base="TString">
      <maxLength value="15"></maxLength>
      <minLength value="1"></minLength>
    </restriction>
  </simpleType>
  <simpleType name="TAnon_qComp_1">
    <restriction base="xs:string">
      <whiteSpace value="preserve"></whiteSpace>
      <pattern value="[0-9]{5}"></pattern>
    </restriction>
  </simpleType>
  <complexType name="TAnonComplex_Comp_1">
    <sequence>
      <element name="xNome" type="TAnon_xNome_2">
        <annotation>
          <documentation>Nome do componente</documentation>
          <documentation>Exxemplos: ISENTOS, VT, CARTAO PRE-PAGO, IDOSOS</documentation>
        </annotation>
      </element>
      <element name="qComp" type="TAnon_qComp_1">
        <annotation>
          <documentation>Quantidade do componente</documentation>
        </annotation>
      </element>
    </sequence>
  </complexType>
  <complexType name="TAnonComplex_det_1">
    <sequence>
      <element name="cMunIni" type="TCodMunIBGE">
        <annotation>
          <documentation>Código do município do início da viagem</documentation>
        </annotation>
      </element>
      <element name="cMunFim" type="TCodMunIBGE" minOccurs="0">
        <annotation>
          <documentation>Código do município do fim da viagem</documentation>
        </annotation>
      </element>
      <element name="nContInicio" minOccurs="0" type="TAnon_nContInicio_1">
        <annotation>
          <documentation>Contador início da viagem</documentation>
        </annotation>
      </element>
      <element name="nContFim" minOccurs="0" type="TAnon_nContFim_1">
        <annotation>
          <documentation>Contador fim da viagem</documentation>
        </annotation>
      </element>
      <element name="qPass" type="TAnon_qPass_1">
        <annotation>
          <documentation>Quantidade de Passagens da viagem</documentation>
        </annotation>
      </element>
      <element name="vBP" type="TDec_1302">
        <annotation>
          <documentation>Valor da soma dos Bilhetes de Passagem da viagem</documentation>
          <documentation>Pode conter zeros quando o BP-e for de complemento de ICMS</documentation>
        </annotation>
      </element>
      <element name="imp" type="TAnonComplex_imp_1">
        <annotation>
          <documentation>Informações relativas aos Impostos</documentation>
        </annotation>
      </element>
      <element name="Comp" maxOccurs="unbounded" type="TAnonComplex_Comp_1">
        <annotation>
          <documentation>Componentes da viagem</documentation>
        </annotation>
      </element>
    </sequence>
    <attribute name="nViagem" use="required">
      <simpleType>
        <restriction base="xs:string">
          <whiteSpace value="preserve"></whiteSpace>
          <pattern value="[1-9]{1}[0-9]{0,1}|[1-8]{1}[0-9]{2}|[9]{1}[0-8]{1}[0-9]{1}|[9]{1}[9]{1}[0]{1}"></pattern>
        </restriction>
      </simpleType>
    </attribute>
  </complexType>
  <complexType name="TAnonComplex_detBPeTM_1">
    <sequence>
      <element name="UFIniViagem" type="TUf_sem_EX">
        <annotation>
          <documentation>Sigla da UF início da Viagem</documentation>
          <documentation>Utilizar a Tabela do IBGE de código de unidades da federação</documentation>
        </annotation>
      </element>
      <element name="UFFimViagem" type="TUf_sem_EX" minOccurs="0">
        <annotation>
          <documentation>Sigla da UF fim da Viagem</documentation>
          <documentation>Utilizar a Tabela do IBGE de código de unidades da federação</documentation>
        </annotation>
      </element>
      <element name="placa" type="TPlaca" minOccurs="0">
        <annotation>
          <documentation>Placa do coletivo</documentation>
        </annotation>
      </element>
      <element name="prefixo" minOccurs="0" type="TAnon_prefixo_1">
        <annotation>
          <documentation>Prefixo da linha</documentation>
        </annotation>
      </element>
      <element name="det" maxOccurs="990" type="TAnonComplex_det_1">
        <annotation>
          <documentation>Datalhamento da viagem por trechos do BPeTM</documentation>
        </annotation>
      </element>
    </sequence>
    <attribute name="idEqpCont" use="required">
      <annotation>
        <documentation>Identificador do equipamento contador</documentation>
      </annotation>
      <simpleType>
        <restriction base="xs:string">
          <whiteSpace value="preserve"></whiteSpace>
          <pattern value="[1-9]{1}[0-9]{0,1}|[1-8]{1}[0-9]{2}|[9]{1}[0-8]{1}[0-9]{1}|[9]{1}[9]{1}[0]{1}"></pattern>
        </restriction>
      </simpleType>
    </attribute>
  </complexType>
  <simpleType name="TAnon_qPass_2">
    <restriction base="xs:string">
      <whiteSpace value="preserve"></whiteSpace>
      <pattern value="[0-9]{1,6}"></pattern>
    </restriction>
  </simpleType>
  <complexType name="TAnonComplex_ICMSTot_1">
    <sequence>
      <element name="vBC" type="TDec_1302">
