    </restriction>
  </simpleType>
  <complexType xmlns="http://www.w3.org/2001/XMLSchema" name="TAnonComplex_imp_1">
    <sequence xmlns="http://www.w3.org/2001/XMLSchema">
      <element xmlns="http://www.w3.org/2001/XMLSchema" name="ICMS" type="TImp">
        <annotation xmlns="http://www.w3.org/2001/XMLSchema">
          <documentation xmlns="http://www.w3.org/2001/XMLSchema">Informações relativas ao ICMS</documentation>
          <documentation xmlns="http://www.w3.org/2001/XMLSchema"></documentation>
        </annotation>
      </element>
      <element xmlns="http://www.w3.org/2001/XMLSchema" name="infAdFisco" minOccurs="0" type="TAnon_infAdFisco_1">
        <annotation xmlns="http://www.w3.org/2001/XMLSchema">
          <documentation xmlns="http://www.w3.org/2001/XMLSchema">Informações adicionais de interesse do Fisco</documentation>
          <documentation xmlns="http://www.w3.org/2001/XMLSchema">Norma referenciada, informações complementares, etc</documentation>
        </annotation>
      </element>
    </sequence>
  </complexType>
  <simpleType xmlns="http://www.w3.org/2001/XMLSchema" name="TAnon_xNome_2">
    <restriction xmlns="http://www.w3.org/2001/XMLSchema" base="TString">
      <maxLength xmlns="http://www.w3.org/2001/XMLSchema" value="15"></maxLength>
      <minLength xmlns="http://www.w3.org/2001/XMLSchema" value="1"></minLength>
    </restriction>
  </simpleType>
  <simpleType xmlns="http://www.w3.org/2001/XMLSchema" name="TAnon_qComp_1">
    <restriction xmlns="http://www.w3.org/2001/XMLSchema" base="xs:string">
      <whiteSpace xmlns="http://www.w3.org/2001/XMLSchema" value="preserve"></whiteSpace>
      <pattern xmlns="http://www.w3.org/2001/XMLSchema" value="[0-9]{5}"></pattern>
    </restriction>
  </simpleType>
  <complexType xmlns="http://www.w3.org/2001/XMLSchema" name="TAnonComplex_Comp_1">
    <sequence xmlns="http://www.w3.org/2001/XMLSchema">
      <element xmlns="http://www.w3.org/2001/XMLSchema" name="xNome" type="TAnon_xNome_2">
        <annotation xmlns="http://www.w3.org/2001/XMLSchema">
          <documentation xmlns="http://www.w3.org/2001/XMLSchema">Nome do componente</documentation>
          <documentation xmlns="http://www.w3.org/2001/XMLSchema">Exxemplos: ISENTOS, VT, CARTAO PRE-PAGO, IDOSOS</documentation>
        </annotation>
      </element>
      <element xmlns="http://www.w3.org/2001/XMLSchema" name="qComp" type="TAnon_qComp_1">
        <annotation xmlns="http://www.w3.org/2001/XMLSchema">
          <documentation xmlns="http://www.w3.org/2001/XMLSchema">Quantidade do componente</documentation>
        </annotation>
      </element>
    </sequence>
  </complexType>
  <complexType xmlns="http://www.w3.org/2001/XMLSchema" name="TAnonComplex_det_1">
    <sequence xmlns="http://www.w3.org/2001/XMLSchema">
      <element xmlns="http://www.w3.org/2001/XMLSchema" name="cMunIni" type="TCodMunIBGE">
        <annotation xmlns="http://www.w3.org/2001/XMLSchema">
          <documentation xmlns="http://www.w3.org/2001/XMLSchema">Código do município do início da viagem</documentation>
        </annotation>
      </element>
      <element xmlns="http://www.w3.org/2001/XMLSchema" name="cMunFim" type="TCodMunIBGE" minOccurs="0">
        <annotation xmlns="http://www.w3.org/2001/XMLSchema">
          <documentation xmlns="http://www.w3.org/2001/XMLSchema">Código do município do fim da viagem</documentation>
