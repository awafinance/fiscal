      </annotation>
    </attribute>
  </complexType>
  <element xmlns="http://www.w3.org/2001/XMLSchema" name="bpeTMProc" type="TAnonComplex_bpeTMProc_1">
    <annotation xmlns="http://www.w3.org/2001/XMLSchema">
      <documentation xmlns="http://www.w3.org/2001/XMLSchema"> BP-e TM processado</documentation>
    </annotation>
  </element>
</schema>