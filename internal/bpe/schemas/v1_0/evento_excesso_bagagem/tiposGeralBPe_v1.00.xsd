  <simpleType name="TLatitude">
    <annotation>
      <documentation>Coordenada geográfica Latitude</documentation>
    </annotation>
    <restriction base="TString">
      <pattern value="[0-9]\.[0-9]{6}|[1-8][0-9]\.[0-9]{6}|90\.[0-9]{6}|-[0-9]\.[0-9]{6}|-[1-8][0-9]\.[0-9]{6}|-90\.[0-9]{6}"></pattern>
    </restriction>
  </simpleType>
  <simpleType name="TLongitude">
    <annotation>
      <documentation>Coordenada geográfica Longitude</documentation>
    </annotation>
    <restriction base="TString">
      <pattern value="[0-9]\.[0-9]{6}|[1-9][0-9]\.[0-9]{6}|1[0-7][0-9]\.[0-9]{6}|180\.[0-9]{6}|-[0-9]\.[0-9]{6}|-[1-9][0-9]\.[0-9]{6}|-1[0-7][0-9]\.[0-9]{6}|-180\.[0-9]{6}"></pattern>
    </restriction>
  </simpleType>
  <simpleType name="TNSU">
    <annotation>
      <documentation>Tipo número sequencial único do AN</documentation>
    </annotation>
    <restriction base="xs:string">
      <pattern value="[0-9]{15}"></pattern>
    </restriction>
  </simpleType>
  <simpleType name="TIPv4">
    <annotation>
      <documentation>Tipo IP versão 4</documentation>
    </annotation>
    <restriction base="xs:string">
      <whiteSpace value="preserve"></whiteSpace>
      <pattern value="(([0-9]|[1-9][0-9]|1[0-9]{2}|2[0-4][0-9]|25[0-5])\.){3}([0-9]|[1-9][0-9]|1[0-9]{2}|2[0-4][0-9]|25[0-5])"></pattern>
    </restriction>
  </simpleType>
  <simpleType name="TPlaca">
    <annotation>
      <documentation>Tipo Placa</documentation>
    </annotation>
    <restriction base="xs:string">
      <whiteSpace value="preserve"></whiteSpace>
      <pattern value="[A-Z]{2,3}[0-9]{4}|[A-Z]{3,4}[0-9]{3}|[A-Z0-9]{7}"></pattern>
    </restriction>
  </simpleType>
</schema>